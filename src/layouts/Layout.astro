---
interface Props {
  title?: string;
  description?: string;
}

const { title = "Shreya Bhadwal", description = "Writing on tech, books, and everything in between." } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title === "Shreya Bhadwal" ? title : `${title} — Shreya Bhadwal`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-name">Shreya Bhadwal</a>
        <ul>
          <li><a href="/" class={currentPath === "/" ? "active" : ""}>Home</a></li>
          <li><a href="/writing" class={currentPath.startsWith("/writing") ? "active" : ""}>Writing</a></li>
          <li><a href="/lately" class={currentPath.startsWith("/lately") ? "active" : ""}>Lately</a></li>
          <li><a href="/about" class={currentPath === "/about" ? "active" : ""}>About</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-contact">
        <a href="mailto:shreya.bhadwal@gmail.com">shreya.bhadwal@gmail.com</a>
        <span class="footer-divider">·</span>
        <a href="https://www.linkedin.com/in/shreya-bhadwal-05aa8b195/" target="_blank" rel="noopener">LinkedIn</a>
      </div>
      <p class="footer-copy">© {new Date().getFullYear()} Shreya Bhadwal · Made with AI. The opinions are still mine.</p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #faf8f5;
    --color-text: #1a1a1a;
    --color-muted: #6b6b6b;
    --color-border: #e4e0d8;
    --color-accent: #7a2d3e;
    --font-serif: 'EB Garamond', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
    --max-width: 680px;
  }

  html {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* Nav */
  header {
    border-bottom: 1px solid var(--color-border);
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .site-name {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  nav ul a {
    font-size: 0.875rem;
    color: var(--color-muted);
    transition: color 0.15s;
    letter-spacing: 0.01em;
  }

  nav ul a:hover,
  nav ul a.active {
    color: var(--color-accent);
  }

  /* Main */
  main {
    flex: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 2rem;
    width: 100%;
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 2rem;
    text-align: center;
  }

  .footer-contact {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin-bottom: 0.4rem;
  }

  .footer-contact a {
    color: var(--color-muted);
    transition: color 0.15s;
  }

  .footer-contact a:hover {
    color: var(--color-text);
  }

  .footer-divider {
    margin: 0 0.5rem;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #aaa;
  }

  /* Typography */
  h1 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  h2 {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }

  p {
    margin-bottom: 1rem;
  }

  @media (max-width: 600px) {
    main, footer {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    nav {
      padding: 0 1.25rem;
      height: auto;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding-top: 1rem;
      padding-bottom: 1rem;
    }

    .site-name {
      font-size: 1.2rem;
    }

    nav ul {
      gap: 1.25rem;
    }
  }
</style>
